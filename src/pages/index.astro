---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .filter(post => !post.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const formatDate = (date: Date) => {
  return date.toLocaleDateString('zh-CN', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  });
};
---

<Layout title="我的博客 - 首页">
  <Header />
  
  <main class="max-w-4xl mx-auto px-4 sm:px-6 py-6 sm:py-8">
    <section class="mb-10 sm:mb-12">
      <h1 class="text-3xl sm:text-4xl font-bold text-gray-900 dark:text-white mb-3 sm:mb-4">欢迎来到我的博客</h1>
      <p class="text-base sm:text-lg text-gray-600 dark:text-gray-400 leading-relaxed">
        记录技术、分享心得。这里有我的学习笔记和生活随笔。
      </p>
    </section>
    
    <section>
      <h2 class="text-xl sm:text-2xl font-bold text-gray-900 dark:text-white mb-5 sm:mb-6">最新文章</h2>
      
      <div class="space-y-4 sm:space-y-6">
        {posts.map((post) => (
          <article class="bg-white dark:bg-gray-800 rounded-xl shadow-sm hover:shadow-md transition-all duration-300 overflow-hidden border border-gray-100 dark:border-gray-700">
            <a href={`/blog/${post.slug}`} class="block p-4 sm:p-6">
              <div class="flex flex-col sm:flex-row gap-4">
                {post.data.heroImage && (
                  <div class="sm:w-40 flex-shrink-0">
                    <img 
                      src={post.data.heroImage} 
                      alt={post.data.title}
                      class="w-full h-40 sm:h-28 object-cover rounded-lg"
                    />
                  </div>
                )}
                <div class="flex-1 min-w-0">
                  <div class="flex items-center gap-2 text-xs sm:text-sm text-gray-500 dark:text-gray-400 mb-2">
                    <time datetime={post.data.pubDate.toISOString()}>
                      {formatDate(post.data.pubDate)}
                    </time>
                    {post.data.categories.length > 0 && (
                      <>
                        <span>·</span>
                        <span class="text-blue-600 dark:text-blue-400 font-medium">
                          {post.data.categories[0]}
                        </span>
                      </>
                    )}
                  </div>
                  
                  <h3 class="text-lg sm:text-xl font-bold text-gray-900 dark:text-white mb-2 hover:text-blue-600 dark:hover:text-blue-400 transition-colors line-clamp-1">
                    {post.data.title}
                  </h3>
                  
                  <p class="text-sm sm:text-base text-gray-600 dark:text-gray-400 mb-3 sm:mb-4 line-clamp-2 leading-relaxed">
                    {post.data.description}
                  </p>
                  
                  <div class="flex flex-wrap gap-1.5 sm:gap-2">
                    {post.data.tags.map((tag) => (
                      <span class="text-xs px-2 py-1 bg-gray-100 dark:bg-gray-700 text-gray-600 dark:text-gray-300 rounded-full font-medium">
                        #{tag}
                      </span>
                    ))}
                  </div>
                </div>
              </div>
            </a>
          </article>
        ))}
      </div>
    </section>
  </main>
  
  <Footer />
</Layout>
