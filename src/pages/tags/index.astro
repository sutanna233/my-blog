---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('blog');
const tags = [...new Set(posts.flatMap(post => post.data.tags))].sort();

const formatDate = (date: Date) => {
  return date.toLocaleDateString('zh-CN', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  });
};
---

<Layout title="标签 - 我的博客">
  <Header />
  
  <main class="max-w-4xl mx-auto px-4 sm:px-6 py-6 sm:py-8">
    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 dark:text-white mb-6 sm:mb-8">标签</h1>
    
    <div class="flex flex-wrap gap-3 sm:gap-4">
      {tags.map((tag) => {
        const tagPosts = posts.filter(post => post.data.tags.includes(tag));
        
        return (
          <a 
            href={`/tags/${tag}`}
            class="flex items-center gap-2 px-4 py-2.5 sm:py-3 bg-white dark:bg-gray-800 rounded-lg shadow-sm hover:shadow-md hover:scale-105 transition-all duration-200 border border-gray-100 dark:border-gray-700"
          >
            <span class="text-gray-900 dark:text-white font-medium">#{tag}</span>
            <span class="text-xs sm:text-sm text-gray-500 dark:text-gray-400 bg-gray-100 dark:bg-gray-700 px-2 py-0.5 rounded-full">
              {tagPosts.length}
            </span>
          </a>
        );
      })}
    </div>
  </main>
  
  <Footer />
</Layout>
